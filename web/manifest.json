{
  "manifest_version": 3,
  "name": "LinkShelf",
  "short_name": "LinkShelf",
  "version": "1.0.0",
  "description": "Your reading list, decaying in real time. Save it or lose it.",
  "action": {
    "default_popup": "index.html",
    "default_title": "Save to LinkShelf"
  },
  "permissions": [
    "activeTab",
    "storage",
    "unlimitedStorage"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "icons": {
    "16": "icons/Icon-192.png",
    "48": "icons/Icon-192.png",
    "128": "icons/Icon-512.png"
  }
}
